generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────
// Auth (NextAuth.js)
// ──────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  recipes  Recipe[]
  favorites Favorite[]
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────
// Recettes
// ──────────────────────────────────

model Recipe {
  id          String     @id @default(cuid())
  title       String
  description String?
  prepTime    Int?       // en minutes
  cookTime    Int?       // en minutes
  servings    Int?
  difficulty  Difficulty @default(MEDIUM)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  ingredients Ingredient[]
  steps       Step[]
  images      RecipeImage[]
  favorites   Favorite[]
  tags        RecipeTag[]

  @@index([userId])
  @@index([categoryId])
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Ingredient {
  id       String  @id @default(cuid())
  name     String
  quantity String? // "200" — stocké en string pour flexibilité ("1/2", "un peu")
  unit     String? // "g", "ml", "pièce", etc.
  order    Int     @default(0)

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model Step {
  id          String @id @default(cuid())
  instruction String
  order       Int    @default(0)

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

// ──────────────────────────────────
// Catégories & Tags
// ──────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  recipes Recipe[]
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  slug    String      @unique
  recipes RecipeTag[]
}

model RecipeTag {
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
}

// ──────────────────────────────────
// Favoris & Images
// ──────────────────────────────────

model Favorite {
  userId    String
  recipeId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}

model RecipeImage {
  id       String @id @default(cuid())
  url      String
  alt      String?
  order    Int    @default(0)

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}